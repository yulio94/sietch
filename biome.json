{
	"$schema": "https://biomejs.dev/schemas/2.4.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"overrides": [
		{
			"includes": [
				"src/i18n/i18n-types.ts",
				"src/i18n/i18n-util.ts",
				"src/i18n/i18n-util.async.ts",
				"src/i18n/i18n-util.sync.ts",
				"src/i18n/formatters.ts",
				".claude/**"
			],
			"linter": { "enabled": false },
			"formatter": { "enabled": false },
			"assist": { "enabled": false }
		}
	],
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
